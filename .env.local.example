# Supabase (optional). If set, sync and auth are available.
# Get these from Supabase dashboard: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 僅本機：用 scripts/export-user-state-rescue.mjs 從 user_state 救援匯出（勿提交、勿加 NEXT_PUBLIC_）
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 可選：網絡極慢時加大 REST 逾時（毫秒）同重試次數
# EXPORT_RESCUE_TIMEOUT_MS=300000
# EXPORT_RESCUE_RETRIES=8

# IELTS「AI 句子填空」：伺服器端呼叫 Gemini（勿用 NEXT_PUBLIC_，避免金鑰外洩）
# 在 Vercel：Project → Settings → Environment Variables 新增同名變數（Production）
GEMINI_API_KEY=AIza...
